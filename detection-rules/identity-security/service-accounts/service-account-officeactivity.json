{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/7c4f8a2e-6b13-4d51-9e2a-3f51d8b6c904')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/7c4f8a2e-6b13-4d51-9e2a-3f51d8b6c904')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "SOC-Medium-ServiceAccounts-OfficeActivity",
                "description": "This analytic rule surfaces any OfficeActivity record performed by an account listed in the 'service-accounts' watchlist. Service accounts should have a predictable, narrow activity profile; any spike, unexpected operation, or new workload usage may indicate credential misuse, privilege abuse, or an attacker leveraging a non-human identity. Read-only / noisy operations are suppressed in the query so analyst attention is focused on actionable events.",
                "severity": "Medium",
                "enabled": true,
                "query": "let ReportPeriod = 2.5h;\r\nlet WatchlistName = \"service-accounts\";\r\nlet SuppressedOperations = dynamic([\r\n    \"UserLoggedIn\"\r\n]);\r\nlet ServiceAccounts =\r\n    _GetWatchlist(WatchlistName)\r\n    | project\r\n        SA_ObjectId    = tostring(ObjectId),\r\n        SA_Name        = tostring(Name),\r\n        SA_Description = tostring(Description),\r\n        SA_UPN         = tolower(tostring(UPN));\r\nOfficeActivity\r\n| where TimeGenerated > ago(ReportPeriod)\r\n| extend UserIdLower = tolower(tostring(UserId))\r\n| lookup kind=inner ServiceAccounts on $left.UserIdLower == $right.SA_UPN\r\n| where Operation !in (SuppressedOperations)\r\n| project\r\n    TimeGenerated,\r\n    SA_Name,\r\n    UserPrincipalName = UserId,\r\n    OfficeWorkload,\r\n    Operation,\r\n    RecordType,\r\n    ResultStatus,\r\n    ClientIP,\r\n    UserAgent,\r\n    OfficeObjectId,\r\n    SourceFileName,\r\n    Site_Url,\r\n    SA_Description\r\n| sort by TimeGenerated desc",
                "queryFrequency": "PT2H",
                "queryPeriod": "PT2H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "InitialAccess",
                    "Persistence",
                    "DefenseEvasion",
                    "LateralMovement"
                ],
                "techniques": [
                    "T1078",
                    "T0859"
                ],
                "subTechniques": [
                    "T1078.004"
                ],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT8H",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDynamicProperties": []
                },
                "customDetails": {},
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "UserPrincipalName"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "ClientIP"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}